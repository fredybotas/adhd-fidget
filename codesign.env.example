# Copy to codesign.env and fill in your values.
# codesign.env is gitignored — never commit it.

# Full name as shown in Keychain: "Developer ID Application: Your Name (TEAMID)"
APPLE_SIGN_IDENTITY="Developer ID Application: Your Name (ABCDE12345)"

# Apple ID used for notarization
APPLE_ID="you@example.com"

# 10-char team ID from developer.apple.com/account
APPLE_TEAM_ID="ABCDE12345"

# App-specific password from appleid.apple.com (not your real password)
APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
